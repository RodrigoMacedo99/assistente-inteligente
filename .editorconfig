root = true

# ── Todos os arquivos ──────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ── Python ────────────────────────────────────────────────────────────────────
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.pyi]
indent_style = space
indent_size = 4

# ── TOML / YAML / JSON ────────────────────────────────────────────────────────
[*.{toml,yml,yaml,json}]
indent_style = space
indent_size = 2

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# ── Makefile ──────────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
