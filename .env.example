# ──────────────────────────────────────────────────────────────────────────────
# AI Adapter - Variáveis de Ambiente
# Copie para .env e preencha as chaves que você possui.
# O sistema funciona com qualquer subconjunto de providers configurados.
# ──────────────────────────────────────────────────────────────────────────────

# ── Ollama (local, gratuito) ───────────────────────────────────────────────────
# Instale em: https://ollama.ai
# Após instalar, rode: ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# ── Groq (free tier: 14.400 req/dia) ──────────────────────────────────────────
# Cadastro gratuito em: https://console.groq.com
GROQ_API_KEY=

# ── Google Gemini (free tier: 1.500 req/dia) ──────────────────────────────────
# Cadastro gratuito em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OpenRouter (free tier: ~200 req/dia com modelos :free) ────────────────────
# Cadastro gratuito em: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_SITE_NAME=AI Adapter

# ── DeepSeek (muito barato: $0.14/$0.28 por 1M tokens) ───────────────────────
# Cadastro com $5 de crédito em: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ── Mistral AI (free tier com créditos) ───────────────────────────────────────
# Cadastro em: https://console.mistral.ai
MISTRAL_API_KEY=

# ── OpenAI (pago, sem free tier significativo) ────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic Claude (pago, sem free tier significativo) ──────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Configurações do servidor ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
